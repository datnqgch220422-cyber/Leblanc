              <span class="account-name">{{ user?.name }}</span>
              <span class="account-email">{{ user?.email }}</span>
            </div>
            <RouterLink
              v-if="isAdmin"
              :to="ADMIN_HOME_PATH"
              class="account-link"
              exact-active-class="active"
              @click="showAccountMenu = false"
            >
